<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="30dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content" >

        <TextView
            android:id="@+id/goal_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:labelFor="@id/day_goal"
            android:text="@string/for_day"
            android:textColor="@color/dark_brown"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/goal_hour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:inputType="number"
            android:labelFor="@id/day_goal_label"
            android:minWidth="48dp"
            android:minHeight="48dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/goal_label" />

        <TextView
            android:id="@+id/goal_hour_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:labelFor="@id/day_goal"
            android:text="ч"
            android:textColor="@color/dark_brown"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/goal_hour"
            app:layout_constraintStart_toEndOf="@+id/goal_hour"
            app:layout_constraintTop_toTopOf="@+id/goal_hour" />

        <EditText
            android:id="@+id/goal_min"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:inputType="number"
            android:labelFor="@id/day_goal_label"
            android:minWidth="48dp"
            android:minHeight="48dp"
            app:layout_constraintStart_toEndOf="@+id/goal_hour_label"
            app:layout_constraintTop_toBottomOf="@+id/goal_label" />

        <TextView
            android:id="@+id/goal_min_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:labelFor="@id/day_goal"
            android:text="мин"
            android:textColor="@color/dark_brown"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/goal_min"
            app:layout_constraintStart_toEndOf="@+id/goal_min"
            app:layout_constraintTop_toTopOf="@+id/goal_min"  />

        <TimePicker
            android:id="@+id/timePicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:scaleX="0.7"
            android:scaleY="0.7"
            android:visibility="gone"
            android:timePickerMode="spinner"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>